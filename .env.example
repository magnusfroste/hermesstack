# Hermes Agent - Environment Variables for Easypanel
# Copy to Easypanel Environment Variables section

# ============================================
# REQUIRED: LLM API Keys (at least one)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# HERMES CONFIGURATION
# ============================================
# Default model (format: provider/model)
HERMES_MODEL=openai/gpt-4o-mini
# HERMES_MODEL=anthropic/claude-sonnet-4.5

# ============================================
# OPTIONAL: Messaging Platform Tokens
# Uncomment and configure if using gateway
# ============================================
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=...
# SLACK_SIGNING_SECRET=...

# ============================================
# OPTIONAL: Search & Tools
# ============================================
# EXA_API_KEY=...
# FIRECRAWL_API_KEY=...
# TAVILY_API_KEY=...

# ============================================
# OPTIONAL: Image Generation
# ============================================
# FAL_KEY=...

# ============================================
# LOGGING (För bättre synlighet i Easypanel)
# ============================================
# Log level: debug, info, warning, error
HERMES_LOG_LEVEL=debug

# Visa all output i console (viktigt för Easypanel logs)
PYTHONUNBUFFERED=1

# ============================================
# EASYPANEL / TRAEFIK DOMAIN
# This will be set automatically by Easypanel
# ============================================
EASYPANEL_DOMAIN=hermes.froste.eu
