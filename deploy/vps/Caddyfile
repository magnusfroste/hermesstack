    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websockets localhost:3002

    log {
        output file /var/log/caddy/operator-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# ============================================
# SUPPLIER AGENT
# ============================================
supplier.froste.eu {
    reverse_proxy localhost:3003 {
        flush_interval -1
    }

    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "*"
    }

    @websockets {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    reverse_proxy @websockets localhost:3003

    log {
        output file /var/log/caddy/supplier-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}
