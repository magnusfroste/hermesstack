# Multi-Agent E-Commerce Setup - Environment Variables
# Copy to .env and fill in your API keys

# ============================================
# LLM PROVIDERS (at least one required)
# ============================================
OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# DEFAULT MODEL
# ============================================
HERMES_MODEL=autoversio
# Other options: openai/gpt-4o, openai/o1-mini, anthropic/claude-sonnet-4-20250514

# ============================================
# FLOWWINK MCP (Operator only)
# ============================================
# FLOWWINK_API_KEY=fwk_...

# ============================================
# SESSION TOKENS (auto-generated by vps-setup.sh)
# ============================================
# HERMES_OPERATOR_TOKEN=hermes-op-xxxxxxxx
# HERMES_CUSTOMER_TOKEN=hermes-cu-xxxxxxxx
# HERMES_SUPPLIER_TOKEN=hermes-su-xxxxxxxx

# ============================================
# LOGGING
# ============================================
HERMES_LOG_LEVEL=info
PYTHONUNBUFFERED=1

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://hermes-redis:6379
