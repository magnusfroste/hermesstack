# Multi-Agent E-Commerce Setup - Environment Variables
# Copy to Easypanel or rename to .env for docker-compose

# ============================================
# REQUIRED: LLM API Keys (at least one)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# HERMES MODEL CONFIGURATION
# ============================================
HERMES_MODEL=openai/gpt-4o-mini
# HERMES_MODEL=anthropic/claude-sonnet-4.5

# ============================================
# FLOWWINK MCP INTEGRATION (Operator only)
# ============================================
# Required for BSS operator to connect to Flowwink ERP/CRM/CMS
# Format: fwk_<hash>
FLOWWINK_API_KEY=fwk_1cf484bf2fe6cd480b20ac7af53d5cf2dae5382f1a7c51c3f5042dd8bc26a369

# ============================================
# OPTIONAL: Advanced LLM Configuration
# ============================================
# HERMES_FALLBACK_MODEL=openai/gpt-4o
# REASONING_EFFORT=medium

# ============================================
# EASYPANEL / TRAEFIK DOMAINS
# These will be set automatically by Easypanel
# ============================================
# Customer agent
EASYPANEL_DOMAIN_CUSTOMER=customer.hermes.froste.eu
# Operator agent (main BSS interface)
EASYPANEL_DOMAIN_OPERATOR=operator.hermes.froste.eu
# Supplier agent
EASYPANEL_DOMAIN_SUPPLIER=supplier.hermes.froste.eu

# ============================================
# INTER-AGENT COMMUNICATION (optional)
# Used for direct HTTP calls between agents
# ============================================
CUSTOMER_URL=http://hermes-customer:3000
OPERATOR_URL=http://hermes-operator:3000
SUPPLIER_URL=http://hermes-supplier:3000

# ============================================
# REDIS CONFIGURATION (for message queue)
# ============================================
REDIS_URL=redis://hermes-redis:6379
