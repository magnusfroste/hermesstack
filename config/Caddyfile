# HermesHotel — Caddy Configuration
# Placera i /etc/caddy/Caddyfile
#
# När du lägger till nya Hermes-instanser via TUI eller add-hermes.sh
# uppdateras denna fil automatiskt med nya domän-block.
# Efter ändring: sudo caddy reload

{
    admin localhost:2019
}

(hermes_headers) {
    @options method OPTIONS
    respond @options 204

    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "X-Hermes-Session-Token, Authorization, Content-Type, Accept, Origin, X-Requested-With"
        Access-Control-Expose-Headers "X-Hermes-Session-Token"
        Access-Control-Max-Age "3600"
        Cache-Control "no-store"
    }
}

# ============================================
# HERMESHOTEL LIGHT PANEL
# ============================================
hermeshotel.froste.eu {
    reverse_proxy localhost:3099

    log {
        output file /var/log/caddy/hermeshotel-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# ============================================
# OPERATOR AGENT
# ============================================
operator.froste.eu {
    import hermes_headers

    reverse_proxy localhost:3002 {
        flush_interval -1
    }

    log {
        output file /var/log/caddy/operator-access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}
